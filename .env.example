# ===========================================
# Blue Bricks — Environment Variables
# ===========================================
# Kopieer dit bestand naar backend/.env en frontend/.env
# Vul de waarden in met je project-specifieke configuratie
# NOOIT echte waarden committen naar git!

# -------------------------------------------
# Backend
# -------------------------------------------

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Supabase (server-side — GEEN VITE_ prefix!)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server
PORT=3001
NODE_ENV=development

# -------------------------------------------
# Frontend
# -------------------------------------------

# Supabase (client-side — VITE_ prefix verplicht)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# API
VITE_API_URL=http://localhost:3001/api

# -------------------------------------------
# MCP Servers (voor Claude Code integratie)
# -------------------------------------------

# Sentry — error monitoring
VITE_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# DigitalOcean — infrastructure management
DIGITALOCEAN_API_TOKEN=your-digitalocean-api-token
